{
  "name": "ben-ai",
  "displayName": "Ben.AI — Multi-Agent Coding Assistant",
  "description": "Multi-agent VS Code extension that generates, modifies and maintains a complete software project automatically. Features: AI chat, code generation, test generation, documentation, refactoring, security scanning, and project building.",
  "version": "0.2.0",
  "publisher": "ben-belaouedj",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ben-belaouedj/ben-ai"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Programming Languages", "Other"],
  "keywords": ["ai", "copilot", "gpt", "claude", "ollama", "code generation", "testing", "documentation", "refactoring"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ben-ai.chat",
        "title": "Ben.AI: Chat",
        "icon": "$(comment)"
      },
      {
        "command": "ben-ai.edit",
        "title": "Ben.AI: Edit Active File",
        "icon": "$(edit)"
      },
      {
        "command": "ben-ai.buildProject",
        "title": "Ben.AI: Build Project",
        "icon": "$(rocket)"
      },
      {
        "command": "ben-ai.generateTests",
        "title": "Ben.AI: Generate Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "ben-ai.generateDocs",
        "title": "Ben.AI: Generate Documentation",
        "icon": "$(book)"
      },
      {
        "command": "ben-ai.generateReadme",
        "title": "Ben.AI: Generate README",
        "icon": "$(file-text)"
      },
      {
        "command": "ben-ai.refactor",
        "title": "Ben.AI: Refactor Code",
        "icon": "$(wrench)"
      },
      {
        "command": "ben-ai.extractFunction",
        "title": "Ben.AI: Extract Function",
        "icon": "$(symbol-function)"
      },
      {
        "command": "ben-ai.analyze",
        "title": "Ben.AI: Analyze File",
        "icon": "$(search)"
      },
      {
        "command": "ben-ai.securityScan",
        "title": "Ben.AI: Security Scan",
        "icon": "$(shield)"
      },
      {
        "command": "ben-ai.explain",
        "title": "Ben.AI: Explain Code",
        "icon": "$(lightbulb)"
      },
      {
        "command": "ben-ai.indexProject",
        "title": "Ben.AI: Index Project",
        "icon": "$(database)"
      },
      {
        "command": "ben-ai.setApiKey",
        "title": "Ben.AI: Set API Key",
        "icon": "$(key)"
      },
      {
        "command": "ben-ai.showPanel",
        "title": "Ben.AI: Open Panel",
        "icon": "$(layout-sidebar-left)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ben-ai-sidebar",
          "title": "Ben.AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ben-ai-sidebar": [
        {
          "type": "webview",
          "id": "ben-ai.sidebarView",
          "name": "Ben.AI"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "ben-ai.edit",
          "group": "ben-ai@1"
        },
        {
          "command": "ben-ai.explain",
          "group": "ben-ai@2"
        },
        {
          "command": "ben-ai.refactor",
          "group": "ben-ai@3"
        },
        {
          "command": "ben-ai.extractFunction",
          "when": "editorHasSelection",
          "group": "ben-ai@4"
        },
        {
          "command": "ben-ai.generateTests",
          "group": "ben-ai@5"
        },
        {
          "command": "ben-ai.generateDocs",
          "group": "ben-ai@6"
        },
        {
          "command": "ben-ai.analyze",
          "group": "ben-ai@7"
        },
        {
          "command": "ben-ai.securityScan",
          "group": "ben-ai@8"
        }
      ],
      "editor/title": [
        {
          "command": "ben-ai.chat",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ben-ai.chat",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "ben-ai.edit",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      },
      {
        "command": "ben-ai.showPanel",
        "key": "ctrl+shift+p b",
        "mac": "cmd+shift+p b"
      }
    ],
    "configuration": {
      "title": "Ben.AI",
      "properties": {
        "ben-ai.provider": {
          "type": "string",
          "default": "ollama",
          "enum": ["ollama", "openai", "anthropic"],
          "enumDescriptions": [
            "Use local Ollama server (free, private)",
            "Use OpenAI API (requires API key)",
            "Use Anthropic Claude API (requires API key)"
          ],
          "description": "Default AI provider for chat and code generation"
        },
        "ben-ai.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "ben-ai.ollamaModel": {
          "type": "string",
          "default": "codellama",
          "description": "Default Ollama model for code tasks"
        },
        "ben-ai.openaiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "enum": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo", "gpt-3.5-turbo"],
          "description": "Default OpenAI model"
        },
        "ben-ai.anthropicModel": {
          "type": "string",
          "default": "claude-3-haiku-20240307",
          "enum": ["claude-3-5-sonnet-20241022", "claude-3-haiku-20240307", "claude-3-opus-20240229"],
          "description": "Default Anthropic Claude model"
        },
        "ben-ai.maxContextTokens": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "maximum": 32000,
          "description": "Maximum tokens to include in context window"
        },
        "ben-ai.autoIndex": {
          "type": "boolean",
          "default": false,
          "description": "Automatically index project on startup"
        },
        "ben-ai.allowedCommands": {
          "type": "array",
          "default": ["npm", "npx", "yarn", "pnpm", "node", "python3", "pip", "git", "tsc", "cargo", "go", "make"],
          "description": "Whitelisted terminal commands that Ben.AI can execute"
        },
        "ben-ai.confirmBeforeDelete": {
          "type": "boolean",
          "default": true,
          "description": "Ask confirmation before deleting files"
        },
        "ben-ai.streamResponses": {
          "type": "boolean",
          "default": true,
          "description": "Stream AI responses in real-time"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
